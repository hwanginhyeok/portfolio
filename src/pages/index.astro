---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CaseCard from '../components/CaseCard.astro';
import ThemeHeatmap from '../components/ThemeHeatmap.astro';
import Timeline from '../components/Timeline.astro';
import cases from '../data/cases.json';
---

<BaseLayout title="황인혁 — 물리 세계의 문제를 데이터로 해결하는 엔지니어">
  <!-- Layer 1: 10초 스캔 -->
  <Hero />

  <!-- Layer 2: 2분 읽기 -->
  <main class="max-w-5xl mx-auto px-6">

    <!-- 케이스 카드: EOP + SS500 + 특허 -->
    <section class="py-12">
      <h2 class="text-2xl font-bold text-primary mb-2">프로젝트 케이스</h2>
      <p class="text-sm text-muted mb-6">EOP 400W + SS500에서 해결한 실제 문제들</p>

      <div class="grid md:grid-cols-2 gap-6">
        {cases.map((c) => (
          <CaseCard {...c} />
        ))}
      </div>
    </section>

    <!-- 경력 타임라인 -->
    <Timeline />

    <!-- 테마 히트맵 -->
    <ThemeHeatmap />

    <!-- About -->
    <section class="py-12 border-t border-gray-100">
      <h2 class="text-2xl font-bold text-primary mb-4">About</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h3 class="font-bold text-lg mb-2">현재</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li><strong>전력제어개발팀 · 선임연구원</strong> — 모터제어, 전력설계, 시험검증</li>
            <li><strong>제품개발팀 · PM 겸임</strong> — 이슈 트래킹, BOM, 양산 준비</li>
          </ul>

          <h3 class="font-bold text-lg mt-6 mb-2">학력</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li><strong>석사</strong> — 모터 모델링/고장진단(PHM), 논문 5편</li>
            <li><strong>학부</strong> — 기계공학부 기계설계학과</li>
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-lg mb-2">기술</h3>
          <div class="flex flex-wrap gap-2 text-sm">
            {['BLDC/PMSM 모터제어', 'FOC/SVPWM', 'CAN/CAN-FD',
              'STM32 · NXP MCU', 'BMS 정합성', 'DFMEA/APQP',
              'Python', 'C/C++', 'Matlab/Simulink',
              'Git', 'Claude Code', 'ROS2'
            ].map((skill) => (
              <span class="bg-surface px-3 py-1 rounded-full text-muted">{skill}</span>
            ))}
          </div>

          <h3 class="font-bold text-lg mt-6 mb-2">사이드 프로젝트</h3>
          <div class="flex flex-wrap gap-2 text-sm">
            {[
              '자율주행 ROS2+Gazebo',
              '정치통계 Next.js',
              '주식분석 Python',
              '음악 프로덕션',
              'AI 개발 자동화',
              '포트폴리오 (이 사이트)'
            ].map((proj) => (
              <span class="bg-blue-50 px-3 py-1 rounded-full text-blue-600">{proj}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-8 border-t border-gray-100 text-center text-sm text-muted">
      <p>황인혁 · 물리 세계의 문제를 데이터로 해결하는 엔지니어</p>
      <p class="mt-1">
        <a href="https://github.com/hwanginhyeok" class="text-accent hover:underline">GitHub</a>
      </p>
    </footer>
  </main>
</BaseLayout>
