---
// 히어로 v4: 전시회 제품 사진 추가 — 텍스트 좌 / 이미지 우
const base = import.meta.env.BASE_URL;
---

<section class="bg-primary text-white overflow-hidden">
  <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <div class="grid md:grid-cols-5 gap-8 items-center">
      <!-- 좌: 텍스트 (3/5) -->
      <div class="md:col-span-3">
        <p class="text-sm tracking-widest text-gray-400 uppercase mb-4">Motor Control · System Engineering · Test Planning</p>
        <h1 class="font-display text-3xl md:text-5xl font-black leading-tight mb-6">
          물리 세계의 문제를<br />
          데이터로 해결하는 엔지니어
        </h1>

        <p class="text-lg text-gray-300 max-w-xl mb-10">
          모터제어 전문성(EOP 400W)과 제품 개발 경험(GT-SS500).
          시험을 기획하고, 현장에서 문제를 찾고, 데이터로 해결합니다.
        </p>

        <div class="flex flex-wrap gap-x-8 gap-y-4 text-sm">
          <div>
            <span class="text-2xl font-black text-white">14건</span>
            <span class="text-gray-400 ml-1">전력제어 이슈 직접 담당</span>
          </div>
          <div>
            <span class="text-2xl font-black text-white">-40°C</span>
            <span class="text-gray-400 ml-1">극저온 기동 300→100초</span>
          </div>
          <div>
            <span class="text-2xl font-black text-white">특허 1</span>
            <span class="text-gray-400 ml-1">+ 논문 5편</span>
          </div>
          <div>
            <span class="text-2xl font-black text-white">6개</span>
            <span class="text-gray-400 ml-1">사이드 프로젝트 진행 중</span>
          </div>
        </div>
      </div>

      <!-- 우: 제품 사진 (2/5) -->
      <div class="md:col-span-2 relative">
        <img
          src={`${base}images/hero/product-front.webp`}
          alt="PLUVA FRIEND GT-SS500 — 농업용 전동 자율주행 Speed Sprayer"
          class="rounded-lg shadow-2xl w-full object-cover"
          loading="eager"
          width="640"
          height="480"
        />
        <p class="text-xs text-gray-500 mt-2 text-center">PLUVA FRIEND GT-SS500</p>
      </div>
    </div>
  </div>
</section>
