---
// 경력 타임라인: 학부 → 석사 → 주임 → 선임
const timeline = [
  {
    period: '2015 — 2021',
    title: '기계공학부 기계설계학과',
    role: '학부',
    detail: '',
  },
  {
    period: '2021 — 2023',
    title: '대학원 석사',
    role: '석사과정',
    detail: '120kW 모터 모델링 · 고장진단(PHM) · 현대/현대로템 과제 4개 · 논문 5편(1저자 3)',
    tools: 'Matlab · Simulink · Ansys MAXWELL',
  },
  {
    period: '2023.02 — 2024.12',
    title: 'GINT 전력제어개발팀',
    role: '주임연구원',
    detail: '다이나모 벤치 구축 · SCU(현대/DIC) BLDC 제어 · EOP 400W 국책과제 · 특허 2건 출원',
    tools: 'C · NXP MCU · CAN · FOC/SVPWM',
  },
  {
    period: '2025.01 —',
    title: 'GINT 전력제어개발팀 + 제품개발팀(PM)',
    role: '선임연구원',
    detail: 'SS500 전력설계 통합 · 구동/펌프/BMS 검증 · 자율주행 연동 · 이슈 37건 트래킹',
    tools: 'STM32 · CAN-FD · Python · Claude Code',
  },
];
---

<section class="py-12">
  <h2 class="text-2xl font-bold text-primary mb-8">경력</h2>

  <div class="relative">
    <!-- 세로 라인 -->
    <div class="absolute left-4 md:left-6 top-0 bottom-0 w-0.5 bg-gray-200"></div>

    <div class="space-y-8">
      {timeline.map((item, i) => (
        <div class="relative pl-12 md:pl-16">
          <!-- 도트 -->
          <div class={`absolute left-2.5 md:left-4.5 w-3 h-3 rounded-full border-2 border-white ${i === timeline.length - 1 ? 'bg-accent' : 'bg-gray-400'}`}></div>

          <div class="text-xs text-muted mb-1">{item.period}</div>
          <h3 class="text-base font-bold text-primary">{item.title}</h3>
          <span class="text-xs bg-surface text-muted px-2 py-0.5 rounded-full">{item.role}</span>
          {item.detail && <p class="text-sm text-gray-600 mt-2">{item.detail}</p>}
          {item.tools && <p class="text-xs text-muted mt-1">{item.tools}</p>}
        </div>
      ))}
    </div>
  </div>
</section>
