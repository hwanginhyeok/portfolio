---
// 케이스 카드: 문제 → 역할 → 핵심 수치 3줄 표시 (Design Review 반영)
interface Props {
  id: string;
  title: string;
  subtitle: string;
  metric: string;
  metricLabel: string;
  problem: string;
  role: string;
  result: string;
  themes: string[];
}

const { id, title, subtitle, metric, metricLabel, problem, role, result, themes } = Astro.props;

const themeColors: Record<string, string> = {
  'T-1': 'bg-blue-100 text-blue-700',
  'T-2': 'bg-green-100 text-green-700',
  'T-3': 'bg-purple-100 text-purple-700',
  'T-4': 'bg-orange-100 text-orange-700',
  'T-5': 'bg-cyan-100 text-cyan-700',
  'T-6': 'bg-red-100 text-red-700',
  'T-7': 'bg-yellow-100 text-yellow-800',
};

const themeNames: Record<string, string> = {
  'T-1': '모터제어', 'T-2': 'CAN', 'T-3': 'PCB/HW',
  'T-4': '시험장비', 'T-5': '데이터', 'T-6': '양산', 'T-7': '문제해결',
};
---

<a href={`${import.meta.env.BASE_URL}cases/${id}/`} class="block">
<article class="group bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg hover:border-accent transition-all duration-200 cursor-pointer">
  <!-- 메트릭 배지 -->
  <div class="flex items-start justify-between mb-3">
    <div>
      <span class="text-2xl font-black text-accent">{metric}</span>
      <span class="text-sm text-muted ml-1">{metricLabel}</span>
    </div>
  </div>

  <!-- 제목 -->
  <h3 class="text-lg font-bold text-primary mb-1">{title}</h3>
  <p class="text-sm text-muted mb-4">{subtitle}</p>

  <!-- 문제 → 역할 → 결과 (Design Review: 카드만으로 1분 결정 가능) -->
  <div class="space-y-2 text-sm">
    <div class="flex gap-2">
      <span class="text-red-500 font-medium shrink-0">문제</span>
      <span class="text-gray-600">{problem}</span>
    </div>
    <div class="flex gap-2">
      <span class="text-blue-500 font-medium shrink-0">역할</span>
      <span class="text-gray-600">{role}</span>
    </div>
    <div class="flex gap-2">
      <span class="text-green-500 font-medium shrink-0">결과</span>
      <span class="text-gray-600">{result}</span>
    </div>
  </div>

  <!-- 테마 태그 -->
  <div class="flex gap-1.5 mt-4 flex-wrap">
    {themes.map((t) => (
      <span class={`text-xs px-2 py-0.5 rounded-full ${themeColors[t] || 'bg-gray-100 text-gray-600'}`}>
        {themeNames[t] || t}
      </span>
    ))}
  </div>
  <!-- 더보기 -->
  <div class="mt-4 text-xs text-accent group-hover:underline">자세히 보기 →</div>
</article>
</a>
